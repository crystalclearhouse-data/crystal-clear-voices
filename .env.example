# Crystal Clear Voices — Root Environment Example
# Copy to .env and fill in values
# Each service also has its own .env (voice-server/.env, api-server/.env)

# ============================================================================
# DATABASE
# ============================================================================

# Prisma / direct connection (postgresql://user:pass@host:5432/db)
DATABASE_URL=postgresql://postgres:localdev@localhost:5432/crystalcleardb

# Individual vars (api-server uses these)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crystalcleardb
DB_USER=postgres
DB_PASSWORD=localdev

# Supabase (dev/staging)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Postgres MCP — restricted read-only role (run supabase/migrations/001_mcp_reader_role.sql first)
# NEVER set this to the service role or postgres superuser connection string
MCP_DB_URL=postgresql://mcp_reader:<password>@db.<ref>.supabase.co:5432/postgres
POSTGRES_ALLOWED_TABLES=posts,profiles,scheduled_content
POSTGRES_MAX_ROWS=100

# ============================================================================
# ANTHROPIC / CLAUDE
# ============================================================================

ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6

# ============================================================================
# ELEVENLABS TTS
# ============================================================================

ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2

# ============================================================================
# PERPLEXITY
# ============================================================================

PERPLEXITY_API_KEY=pplx-...

# ============================================================================
# TWILIO
# ============================================================================

TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...
# SK-format API key from console.twilio.com/project/api-keys (for MCP)
TWILIO_MCP_API_KEY=SK...
TWILIO_MCP_API_SECRET=

# Public-facing URL for Twilio webhooks
# Local dev:  ngrok http 3001  →  copy the https URL here
#             e.g. https://abc123.ngrok-free.app
# Production: https://voice.thediscobass.com
#
# Twilio console → Phone Numbers → your number → Voice config:
#   Voice webhook:  ${PUBLIC_URL}/twilio/voice   (HTTP POST)
#   SMS webhook:    ${PUBLIC_URL}/twilio/sms      (HTTP POST)
#
# /speak endpoint payload (POST application/json):
#   { "message": "Hello world" }          ← "message" key required
#   { "text": "..." }                     ← WRONG — returns 400
PUBLIC_URL=

# ============================================================================
# n8n
# ============================================================================

N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_TOKEN=

# ============================================================================
# SOCIAL MEDIA (Meta + TikTok)
# ============================================================================

META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# Social MCP safety
SOCIAL_ALLOWED_PLATFORMS=facebook,instagram,tiktok
SOCIAL_MAX_POST_LENGTH=1000

# ============================================================================
# COMMUNICATIONS & PRODUCTIVITY
# ============================================================================

OUTLOOK_CLIENT_ID=
DISCORD_BOT_TOKEN=
NOTION_TOKEN=

# Notion database IDs (Settings → ... → Copy link → extract 32-char hex ID)
NOTION_CLIENTS_DB_ID=
NOTION_BLUEPRINTS_DB_ID=
NOTION_CREATORS_DB_ID=
# n8n intake + blueprint alert channel
DISCORD_INTAKE_WEBHOOK_URL=

# ============================================================================
# CREWAI
# ============================================================================

CREWAI_ORG_ID=a1751f49-7303-4399-8bab-e3b9b5f3d834
CREWAI_API_KEY=

# ============================================================================
# BACK-OFFICE SERVICES
# ============================================================================

# CrewAI FastAPI service
# Local:      http://localhost:8000
# Production: https://crew.voice.thediscobass.com
CREW_SERVICE_URL=http://localhost:8000

# ============================================================================
# APP
# ============================================================================

PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# API key protecting /api/* routes on api-server (port 3000)
# Generate: openssl rand -hex 32
API_KEY=

# ============================================================================
# MCP SERVER
# ============================================================================

# Required when running: node mcp-server.js --http (no fallback — server exits if unset)
# Generate: python3 -c "import secrets; print('cch-mcp-' + secrets.token_urlsafe(24))"
MCP_API_KEY=
MCP_PORT=3003

# Crystal Clear Voices — Root Environment Example
# Copy to .env and fill in values
# Each service also has its own .env (voice-server/.env, api-server/.env)

# ============================================================================
# DATABASE
# ============================================================================

# Prisma / direct connection (postgresql://user:pass@host:5432/db)
DATABASE_URL=postgresql://postgres:localdev@localhost:5432/crystalcleardb

# Individual vars (api-server uses these)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crystalcleardb
DB_USER=postgres
DB_PASSWORD=localdev

# Supabase (dev/staging)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# ============================================================================
# ANTHROPIC / CLAUDE
# ============================================================================

ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6

# ============================================================================
# ELEVENLABS TTS
# ============================================================================

ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2

# ============================================================================
# PERPLEXITY
# ============================================================================

PERPLEXITY_API_KEY=pplx-...

# ============================================================================
# TWILIO
# ============================================================================

TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...
# SK-format API key from console.twilio.com/project/api-keys (for MCP)
TWILIO_MCP_API_KEY=SK...
TWILIO_MCP_API_SECRET=

# Public-facing URL for Twilio webhooks
# Local:      set to your ngrok URL, e.g. https://abc123.ngrok-free.app
# Production: https://voice.thediscobass.com
PUBLIC_URL=

# ============================================================================
# n8n
# ============================================================================

N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_TOKEN=

# ============================================================================
# SOCIAL MEDIA (Meta + TikTok)
# ============================================================================

META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# ============================================================================
# COMMUNICATIONS & PRODUCTIVITY
# ============================================================================

OUTLOOK_CLIENT_ID=
DISCORD_BOT_TOKEN=
NOTION_TOKEN=

# ============================================================================
# CREWAI
# ============================================================================

CREWAI_ORG_ID=a1751f49-7303-4399-8bab-e3b9b5f3d834
CREWAI_API_KEY=

# ============================================================================
# BACK-OFFICE SERVICES
# ============================================================================

# CrewAI FastAPI service
# Local:      http://localhost:8000
# Production: https://crew.voice.thediscobass.com
CREW_SERVICE_URL=http://localhost:8000

# ============================================================================
# APP
# ============================================================================

PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

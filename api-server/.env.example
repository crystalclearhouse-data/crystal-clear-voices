# Crystal Clear Voices API - Environment Configuration
# Copy this to .env and fill in your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

DB_HOST=your-rds-cluster-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=crystalcleardb
DB_USER=postgres
DB_PASSWORD=your_secure_database_password_here

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

PORT=3000
NODE_ENV=production

# ============================================================================
# n8n INTEGRATION
# ============================================================================

# Local n8n instance (for development)
# N8N_WEBHOOK_URL=http://localhost:5678

# Remote n8n instance (for production)
N8N_WEBHOOK_URL=https://your-n8n-domain.com

# ============================================================================
# SOCIAL MEDIA API KEYS
# ============================================================================

# Twitter/X
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

# Instagram
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# Facebook
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=your_linkedin_person_urn

# ============================================================================
# AI & PROCESSING SERVICES
# ============================================================================

# OpenAI (for concierge information requests)
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================================================
# EMAIL & NOTIFICATIONS
# ============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM_EMAIL=noreply@voice.thediscobass.com

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=info
# LOG_FILE=/var/log/crystal-clear-voices/api.log

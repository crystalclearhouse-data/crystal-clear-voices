{
  "mcpServers": {
    "google-workspace": {
      "command": "npx",
      "args": [
        "-y",
        "google-workspace-mcp"
      ],
      "env": {}
    },
    "outlook": {
      "command": "npx",
      "args": [
        "-y",
        "outlook-mcp-device-flow"
      ],
      "env": {
        "OUTLOOK_CLIENT_ID": "${OUTLOOK_CLIENT_ID}",
        "OUTLOOK_TENANT_ID": "common"
      }
    },
    "elevenlabs": {
      "command": "npx",
      "args": [
        "-y",
        "elevenlabs-mcp"
      ],
      "env": {
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}"
      }
    },
    "perplexity": {
      "command": "npx",
      "args": [
        "-y",
        "perplexity-mcp"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    },
    "n8n": {
      "command": "npx",
      "args": [
        "-y",
        "n8n-mcp"
      ],
      "env": {
        "N8N_API_URL": "http://localhost:5678",
        "N8N_API_KEY": "${N8N_API_TOKEN}",
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_WEBHOOK_URL": "${N8N_WEBHOOK_URL}"
      }
    },
    "postgres": {
      "command": "node",
      "args": [
        "/home/user/crystal-clear-voices/postgres-mcp.js"
      ],
      "env": {
        "MCP_DB_URL": "${MCP_DB_URL}",
        "POSTGRES_ALLOWED_TABLES": "${POSTGRES_ALLOWED_TABLES}",
        "POSTGRES_MAX_ROWS": "${POSTGRES_MAX_ROWS}"
      }
    },
    "discord": {
      "command": "npx",
      "args": [
        "-y",
        "discord-mcp"
      ],
      "env": {
        "DISCORD_BOT_TOKEN": "${DISCORD_BOT_TOKEN}"
      }
    },
    "linkedin": {
      "command": "npx",
      "args": [
        "-y",
        "linkedin-mcp"
      ]
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_TOKEN": "${NOTION_TOKEN}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/user/crystal-clear-voices",
        "/home/user/rushcall-ai"
      ]
    },
    "twilio": {
      "command": "npx",
      "args": [
        "-y",
        "@twilio-alpha/mcp",
        "--accountSid",
        "${TWILIO_ACCOUNT_SID}",
        "--apiKey",
        "${TWILIO_MCP_API_KEY}",
        "--apiSecret",
        "${TWILIO_MCP_API_SECRET}"
      ],
      "env": {
        "TWILIO_ACCOUNT_SID": "${TWILIO_ACCOUNT_SID}",
        "TWILIO_AUTH_TOKEN": "${TWILIO_AUTH_TOKEN}",
        "PUBLIC_URL": "${PUBLIC_URL}"
      }
    }
  }
}
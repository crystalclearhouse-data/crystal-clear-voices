{
  "mcpServers": {
    "google-workspace": {
      "command": "npx",
      "args": [
        "-y",
        "google-workspace-mcp"
      ],
      "env": {}
    },
    "outlook": {
      "command": "npx",
      "args": [
        "-y",
        "outlook-mcp-device-flow"
      ],
      "env": {
        "OUTLOOK_CLIENT_ID": "${OUTLOOK_CLIENT_ID}",
        "OUTLOOK_TENANT_ID": "common"
      }
    },
    "macos": {
      "command": "npx",
      "args": [
        "-y",
        "macos-mcp"
      ]
    },
    "elevenlabs": {
      "command": "npx",
      "args": [
        "-y",
        "elevenlabs-mcp"
      ],
      "env": {
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}"
      }
    },
    "perplexity": {
      "command": "npx",
      "args": [
        "-y",
        "perplexity-mcp"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    },
    "n8n": {
      "command": "npx",
      "args": [
        "-y",
        "n8n-mcp"
      ],
      "env": {
        "N8N_API_URL": "http://localhost:5678",
        "N8N_API_KEY": "${N8N_API_TOKEN}",
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_WEBHOOK_URL": "${N8N_WEBHOOK_URL}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${SUPABASE_DB_URL}"
      ]
    },
    "social-media": {
      "command": "node",
      "args": [
        "/Users/data-house/projects/crystalclearhouse-data/voice-server/social-mcp.js"
      ],
      "env": {
        "META_PAGE_ID": "${META_PAGE_ID}",
        "META_PAGE_ACCESS_TOKEN": "${META_PAGE_ACCESS_TOKEN}",
        "META_IG_USER_ID": "${META_IG_USER_ID}",
        "TIKTOK_ACCESS_TOKEN": "${TIKTOK_ACCESS_TOKEN}",
        "TIKTOK_OPEN_ID": "${TIKTOK_OPEN_ID}",
        "N8N_WEBHOOK_URL": "http://localhost:5678"
      }
    },
    "discord": {
      "command": "npx",
      "args": [
        "-y",
        "discord-mcp"
      ],
      "env": {
        "DISCORD_BOT_TOKEN": "${DISCORD_BOT_TOKEN}"
      }
    },
    "linkedin": {
      "command": "npx",
      "args": [
        "-y",
        "linkedin-mcp"
      ]
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_TOKEN": "${NOTION_TOKEN}"
      }
    },
    "aws-documentation": {
      "command": "/Users/data-house/.local/bin/uvx",
      "args": [
        "awslabs.aws-documentation-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws",
        "PATH": "/Users/data-house/.local/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/data-house/projects/crystalclearhouse-data"
      ]
    },
    "twilio": {
      "command": "npx",
      "args": [
        "-y",
        "@twilio-alpha/mcp",
        "--accountSid",
        "${TWILIO_ACCOUNT_SID}",
        "--apiKey",
        "${TWILIO_MCP_API_KEY}",
        "--apiSecret",
        "${TWILIO_MCP_API_SECRET}"
      ],
      "env": {
        "TWILIO_ACCOUNT_SID": "${TWILIO_ACCOUNT_SID}",
        "TWILIO_AUTH_TOKEN": "${TWILIO_AUTH_TOKEN}",
        "PUBLIC_URL": "${PUBLIC_URL}"
      }
    }
  }
}